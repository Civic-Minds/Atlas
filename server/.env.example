# Postgres connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/atlas

# Server
PORT=3001

# Poll interval in milliseconds (default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# OC Transpo (Ottawa) — register at nextrip.octranspo.com
OC_TRANSPO_API_KEY=

# TriMet (Portland) — register at developer.trimet.org
TRIMET_APP_ID=

# NYC MTA Bus Time — register at bustime.mta.info
MTA_BUS_API_KEY=

# TransLink (Metro Vancouver) — register at developer.translink.ca
TRANSLINK_API_KEY=

# Swiftly — used for RTC Southern Nevada (Las Vegas) and LA Metro Rail
# Request at goswift.ly/realtime-api-key
SWIFTLY_API_KEY=

# San Diego MTS — register at sdmts.com/business-center/app-developers/real-time-data
MTS_API_KEY=

# King County Metro (Seattle RapidRide) — email oba_api_key@soundtransit.org
KCM_OBA_API_KEY=

# Madison Metro Transit — register at metromap.cityofmadison.com/dev-account
MADISON_API_KEY=

# SF Muni — register at 511.org/open-data/token
MUNI_511_API_KEY=

# Foothill Transit (Silver Streak) — requires IP whitelist, email info@foothilltransit.org
# No key needed once whitelisted — just uncomment the agency in config.ts

# Redis
REDIS_URL=redis://localhost:6379

# CORS — frontend origin allowed to call the API
FRONTEND_URL=http://localhost:5173

# Firebase Admin — project ID for JWT verification (server-side)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Notion — database ID for agency intelligence sync
NOTION_DATABASE_ID=your-notion-database-id

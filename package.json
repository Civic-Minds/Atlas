{
  "name": "atlas",
  "private": true,
  "description": "A hosted frequency map for transit routes.",
  "version": "3.1.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "vite",
    "dev:api": "npx tsx api-dev-server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "process": "npx tsx pipeline/process-gtfs.ts",
    "refresh": "npx tsx pipeline/refresh.ts",
    "build-pmtiles": "npx tsx pipeline/build-pmtiles.ts",
    "build-history": "npx tsx pipeline/build-history.ts",
    "migrate-archive": "npx tsx pipeline/migrate-gtfs-archive.ts",
    "validate-headsigns": "npx tsx scripts/validate-headsign-split.ts",
    "validate-index": "npx tsx pipeline/validate-index.ts",
    "sync-feed-refresh-meta": "npx tsx scripts/sync-feed-refresh-meta.ts",
    "poc:burlington": "npx tsx scripts/poc/burlington-rt.ts",
    "poc:hamilton": "npx tsx scripts/poc/hamilton-rt.ts",
    "find-mdb": "npx tsx pipeline/find-mdb-feed.ts",
    "discover-gaps": "npx tsx pipeline/discover-gaps.ts",
    "upload-pmtiles": "npx tsx pipeline/upload-pmtiles.ts",
    "sync-agency-count": "node -e \"const fs=require('fs');const count=JSON.parse(fs.readFileSync('public/data/index.json','utf8')).agencies.length;const p='docs/AGENCIES.md';fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace(/^(\\d+) agencies as of/m,count+' agencies as of'));console.log('Updated AGENCIES.md: '+count+' agencies');\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1079.0",
    "@deck.gl/mapbox": "^9.3.6",
    "deck.gl": "^9.3.6",
    "dotenv": "^17.4.2",
    "gtfs-realtime-bindings": "^2.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "papaparse": "^5.5.4",
    "pmtiles": "^4.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.1"
  },
  "overrides": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}

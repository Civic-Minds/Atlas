{
  "name": "atlas",
  "private": true,
  "description": "A hosted frequency map for transit routes.",
  "version": "2.3.1",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "process": "npx tsx pipeline/process-gtfs.ts",
    "refresh": "npx tsx pipeline/refresh.ts",
    "validate-headsigns": "npx tsx scripts/validate-headsign-split.ts",
    "poc:burlington": "npx tsx scripts/poc/burlington-rt.ts",
    "poc:hamilton": "npx tsx scripts/poc/hamilton-rt.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@types/leaflet.markercluster": "^1.5.6",
    "dotenv": "^17.4.2",
    "gtfs-realtime-bindings": "^2.0.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.16",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}

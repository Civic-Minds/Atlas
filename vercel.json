{
  "rewrites": [
    {
      "source": "/api/gtfs-rt",
      "destination": "/api/gtfs-rt.ts"
    },
    {
      "source": "/api/live-adherence",
      "destination": "/api/live-adherence.ts"
    },
    {
      "source": "/api/live-vehicles",
      "destination": "/api/live-vehicles.ts"
    },
    {
      "source": "/api/live-snapshot",
      "destination": "/api/live-snapshot.ts"
    },
    {
      "source": "/api/live-stop",
      "destination": "/api/live-stop.ts"
    },
    {
      "source": "/api/history-adherence",
      "destination": "/api/history-adherence.ts"
    },
    {
      "source": "/((?!api/|@vite|@react-refresh|node_modules/|src/).*)",
      "destination": "/index.html"
    }
  ]
}

# Atlas environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- R2 (pipeline process/refresh, PMTiles upload, private archive/live reads) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atlas
R2_PUBLIC_URL=https://your-public-atlas-cdn.example
R2_ARCHIVE_BUCKET_NAME=atlas-archive
R2_LIVE_BUCKET_NAME=atlas-live

# --- Live GTFS-RT (Vercel / local dev:api) — only needed for key-gated agencies ---
TRANSLINK_API_KEY=
STM_API_KEY=
MUNI_511_API_KEY=
# Parked LA Metro rail until active:false is flipped
SWIFTLY_API_KEY=

# --- Optional / niche ---
# MDB_REFRESH_TOKEN=   # Mobility Database token for some discovery scripts

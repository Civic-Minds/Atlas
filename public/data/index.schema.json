{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Atlas Agency Index",
  "type": "object",
  "required": ["agencies"],
  "properties": {
    "agencies": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Agency"
      }
    }
  },
  "definitions": {
    "Agency": {
      "type": "object",
      "required": ["slug", "name", "center", "feedUrl"],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "center": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "bbox": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "feedUrl": { "type": ["string", "null"] },
        "mdbFeedUrl": { "type": "string" },
        "supplementalFeedUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastFeedExpiry": { "type": ["string", "null"] },
        "lastFeedVersion": { "type": ["string", "null"] },
        "lastRefreshedAt": { "type": ["string", "null"] },
        "preprocess": { "type": "string" },
        "excludeRouteShortNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "staged": { "type": "boolean" },
        "gtfsFares": { "type": "boolean" },
        "fareUrl": { "type": "string" },
        "issueUrl": { "type": "string" },
        "fare": { "type": "number" }
      },
      "additionalProperties": false,
      "not": {
        "anyOf": [
          { "required": ["url"] },
          { "required": ["stopsUrl"] },
          { "required": ["corridorsUrl"] }
        ]
      }
    }
  }
}
